# MikoPBX AMI (opcional para o painel subir - sem isso, o painel mostra "AMI não configurada")
AMI_HOST=192.168.1.254
AMI_PORT=5038
AMI_USER=ramais_monitor
AMI_SECRET=troque_esta_senha

# Painel web de status
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
# Recomendado quando o painel for acessivel por outros computadores
DASHBOARD_USERNAME=pulsopbx
DASHBOARD_PASSWORD=troque_esta_senha

# Canal de alerta por E-mail. A configuracao e opcional: sem SMTP o
# monitoramento e o painel continuam funcionando normalmente.

# E-mail via SMTP
EMAIL_SMTP_HOST=smtp.office365.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=monitor@empresa.com.br
EMAIL_SMTP_PASSWORD=coloque_a_senha_aqui
EMAIL_FROM=monitor@empresa.com.br
EMAIL_SMTP_STARTTLS=true
EMAIL_SMTP_SSL=false
EMAIL_SMTP_TIMEOUT_SECONDS=10
EMAIL_RECIPIENTS=ti@empresa.com.br

# Ajustes finos (opcional)
DEBOUNCE_SECONDS=30
RECONCILE_SECONDS=60
# Cada destinatario recebe tentativas individuais; os atrasos crescem em 15s, 30s, ...
ALERT_MAX_ATTEMPTS=3
ALERT_RETRY_BASE_SECONDS=15
# Impede dois testes manuais quase simultaneos pelo painel (minimo aceito: 10s)
ALERT_TEST_COOLDOWN_SECONDS=60

# Historico persistente de quedas, retornos e entregas por E-mail.
# Caminho relativo a pasta do monitor.
INCIDENTS_DB_PATH=data/pulsopbx.db

# Modo demonstracao: mostra ramais de exemplo no painel (para testar o visual
# sem a AMI conectada). Deixe "false" ou remova em producao.
DEMO_MODE=false

# Nomes/setores dos ramais: copie ramais_nomes.example.json para ramais_nomes.json
# e preencha. O arquivo e recarregado sozinho quando muda (nao precisa reiniciar).
# So precisa disso se quiser SOBRESCREVER o nome vindo do MikoPBX ou adicionar um
# setor separado - com a API abaixo configurada, o nome ja vem automatico.

# API REST do MikoPBX (opcional): busca automaticamente o nome do funcionario de
# cada ramal (Sistema -> Chaves API no painel do MikoPBX; permissao de Leitura em
# "Employees Management"). Sem isso, o painel so mostra nome se voce preencher
# ramais_nomes.json manualmente.
MIKOPBX_API_KEY=coloque_a_chave_api_aqui
MIKOPBX_API_URL=https://192.168.1.254/pbxcore/api/v3
# Mantenha false enquanto o MikoPBX usar certificado interno/autoassinado. So use true
# depois de instalar um certificado valido e confiavel na maquina do monitor.
MIKOPBX_VERIFY_TLS=false
MIKOPBX_NAMES_REFRESH_SECONDS=300
